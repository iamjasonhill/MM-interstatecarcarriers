{
  "name": "mm-interstatecarcarriers-com-au",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=22.12.0"
  },
  "scripts": {
    "dev": "astro dev",
    "build": "astro build",
    "preview": "astro preview",
    "check": "astro check",
    "check:contract": "node ./scripts/check-contract.mjs && node scripts/check-agent-discovery.mjs",
    "check:seo": "node ./scripts/check-seo.mjs",
    "import:routes": "node ./scripts/import-icc-route-sources.mjs",
    "import:routes:batches": "node ./scripts/import-icc-route-batches.mjs",
    "lint": "astro check",
    "format:check": "prettier --check .",
    "indexnow:dry-run": "node ./scripts/indexnow-submit.mjs --dry-run",
    "indexnow:submit": "node ./scripts/indexnow-submit.mjs --live --force",
    "check:agent-discovery": "node scripts/check-agent-discovery.mjs"
  },
  "dependencies": {
    "@astrojs/rss": "^4.0.18",
    "@astrojs/sitemap": "^3.7.3",
    "@astrojs/vercel": "^11.0.2",
    "@fontsource/barlow-condensed": "^5.2.8",
    "@fontsource/inter": "^5.2.8",
    "@jdevalk/astro-seo-graph": "^2.2.0",
    "@jdevalk/seo-graph-core": "^0.7.0",
    "astro": "^7.0.7",
    "sharp": "^0.34.4"
  },
  "devDependencies": {
    "@astrojs/check": "^0.9.8",
    "cheerio": "^1.2.0",
    "prettier": "^3.7.4",
    "prettier-plugin-astro": "^0.14.1",
    "typescript": "^5.9.3"
  }
}
