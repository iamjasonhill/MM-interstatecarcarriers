---
import { site } from '../config/site';
import type { FooterSection, SiteLink } from '../config/site';

const currentYear = new Date().getFullYear();
const currentPath = Astro.url.pathname;
const isHome = currentPath === '/';
const onPageLinks: SiteLink[] = currentPath === '/enclosed-car-transport-quote/'
  ? [
      { label: 'Top of page', href: '#main-content' },
      { label: 'Who it suits', href: '#service-fit-heading' },
      { label: 'Next step', href: '#service-cta-heading' },
    ]
  : currentPath === '/vehicle-transport-questions/'
    ? [
        { label: 'Top of page', href: '#main-content' },
        { label: 'Questions', href: '#faq-heading' },
        { label: 'Next step', href: '#page-cta-heading' },
      ]
    : [
        { label: 'Top of page', href: '#main-content' },
        { label: 'Home', href: '/' },
        { label: 'Sitemap', href: '/sitemap/' },
      ];
const footerSections: FooterSection[] = isHome
  ? site.footerSections
  : [
      {
        heading: 'On this page',
        links: onPageLinks,
      },
      {
        heading: 'Site pages',
        links: [
          { label: 'Home', href: '/' },
          { label: 'Enclosed Transport', href: '/enclosed-car-transport-quote/' },
          { label: 'Vehicle Questions', href: '/vehicle-transport-questions/' },
          { label: 'HTML Sitemap', href: '/sitemap/' },
        ],
      },
      {
        heading: 'External actions',
        links: [
          {
            label: 'Vehicle Quote',
            href: site.primaryCta.href,
            external: site.primaryCta.external,
          },
          {
            label: 'Contact',
            href: site.secondaryCta.href,
            external: site.secondaryCta.external,
          },
        ],
      },
    ];
---

<footer class="footer" aria-labelledby="footer-heading">
  <h2 id="footer-heading" class="sr-only">Footer</h2>

  <div class="footer-inner">

    <div class="footer-top">

      <!-- Brand column -->
      <div class="footer-brand">
        <a href="/" class="footer-logo" aria-label={`${site.name} home`}>
          <span class="footer-logo-dot" aria-hidden="true"></span>
          {site.name}
        </a>
        <p class="footer-tagline">
          {site.tagline}
        </p>
        <a
          href={site.secondaryCta.href}
          class="footer-cta"
          target={site.secondaryCta.external ? '_blank' : undefined}
          rel={site.secondaryCta.external ? 'noreferrer' : undefined}
        >
          {site.secondaryCta.label}
        </a>
        <div class="footer-contact">
          <a
            href={site.primaryCta.href}
            class="footer-contact-link"
            target={site.primaryCta.external ? '_blank' : undefined}
            rel={site.primaryCta.external ? 'noreferrer' : undefined}
          >
            {site.primaryCta.label}
          </a>
          <a
            href={site.secondaryCta.href}
            class="footer-contact-link"
            target={site.secondaryCta.external ? '_blank' : undefined}
            rel={site.secondaryCta.external ? 'noreferrer' : undefined}
          >
            {site.secondaryCta.label}
          </a>
        </div>
      </div>

      <nav class="footer-nav" aria-label="Footer navigation">
        {footerSections.map(({ heading, links }) => (
          <div class="footer-nav-col">
            <h3 class="footer-nav-heading">{heading}</h3>
            <ul role="list">
              {links.map(({ label, href, external }) => (
                <li>
                  <a
                    href={href}
                    class="footer-nav-link"
                    target={external ? '_blank' : undefined}
                    rel={external ? 'noreferrer' : undefined}
                  >
                    {label}
                  </a>
                </li>
              ))}
            </ul>
          </div>
        ))}
      </nav>

    </div>

    <div class="footer-bottom">
      <p class="footer-legal">
        &copy; {currentYear} {site.name}. Australia-wide vehicle transport for standard, prestige, and specialist vehicles.
      </p>
      <div class="footer-bottom-links">
        <a href="/sitemap/" class="footer-bottom-link">Sitemap</a>
        <a href="#main-content" class="footer-bottom-link">Back to content</a>
      </div>
    </div>

  </div>
</footer>

<style>
  .footer {
    background:
      radial-gradient(circle at top right, rgba(58, 143, 214, 0.08), transparent 22rem),
      #11161d;
    border-top: 1px solid var(--color-border);
    margin-top: auto;
  }

  .footer-inner {
    max-width: var(--container-max);
    margin-inline: auto;
    padding-inline: var(--space-6);
    padding-block: var(--space-20) var(--space-10);
  }

  /* Top section */
  .footer-top {
    display: grid;
    grid-template-columns: 1fr 2fr;
    gap: var(--space-16);
    padding-bottom: var(--space-14);
    border-bottom: 1px solid var(--color-border);
  }

  /* Brand */
  .footer-logo {
    font-family: var(--font-display);
    font-weight: var(--weight-black);
    font-size: var(--text-lg);
    letter-spacing: var(--tracking-wide);
    text-transform: uppercase;
    color: var(--color-ink-primary);
    display: flex;
    align-items: center;
    gap: var(--space-2);
    margin-bottom: var(--space-4);
    width: fit-content;
  }

  .footer-logo-dot {
    width: 7px;
    height: 7px;
    background: var(--color-accent);
    border-radius: 50%;
    flex-shrink: 0;
  }

  .footer-tagline {
    font-size: var(--text-sm);
    line-height: var(--leading-loose);
    color: var(--color-ink-secondary);
    margin-bottom: var(--space-6);
    max-width: 28ch;
  }

  .footer-cta {
    display: inline-block;
    font-family: var(--font-display);
    font-weight: var(--weight-bold);
    font-size: var(--text-sm);
    letter-spacing: var(--tracking-wide);
    text-transform: uppercase;
    color: var(--color-accent-text);
    background: var(--color-accent);
    padding: var(--space-2) var(--space-5);
    border-radius: var(--radius-sm);
    margin-bottom: var(--space-6);
    transition: background var(--duration-fast) var(--ease-standard);
  }

  .footer-cta:hover {
    background: var(--color-accent-hover);
  }

  .footer-contact {
    display: flex;
    flex-direction: column;
    gap: var(--space-1);
  }

  .footer-contact-link {
    font-size: var(--text-sm);
    color: var(--color-ink-secondary);
    transition: color var(--duration-fast) var(--ease-standard);
  }

  .footer-contact-link:hover {
    color: var(--color-accent);
  }

  /* Nav columns */
  .footer-nav {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: var(--space-8);
  }

  .footer-nav-heading {
    font-size: var(--text-xs);
    font-weight: var(--weight-medium);
    letter-spacing: var(--tracking-widest);
    text-transform: uppercase;
    color: var(--color-ink-muted);
    margin-bottom: var(--space-4);
  }

  .footer-nav-col ul {
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
    list-style: none;
    padding: 0;
    margin: 0;
  }

  .footer-nav-link {
    font-size: var(--text-sm);
    color: var(--color-ink-secondary);
    transition: color var(--duration-fast) var(--ease-standard);
  }

  .footer-nav-link:hover {
    color: var(--color-ink-primary);
  }

  /* Bottom bar */
  .footer-bottom {
    padding-top: var(--space-8);
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: var(--space-4);
    flex-wrap: wrap;
  }

  .footer-legal {
    font-size: var(--text-xs);
    color: var(--color-ink-muted);
  }

  .footer-bottom-links {
    display: flex;
    gap: var(--space-5);
  }

  .footer-bottom-link {
    font-size: var(--text-xs);
    color: var(--color-ink-muted);
    transition: color var(--duration-fast) var(--ease-standard);
  }

  .footer-bottom-link:hover {
    color: var(--color-ink-secondary);
  }

  /* Responsive */
  @media (max-width: 900px) {
    .footer-top {
      grid-template-columns: 1fr;
      gap: var(--space-10);
    }

    .footer-tagline {
      max-width: 100%;
    }
  }

  @media (max-width: 600px) {
    .footer-nav {
      grid-template-columns: repeat(2, 1fr);
    }

    .footer-bottom {
      flex-direction: column;
      align-items: flex-start;
    }
  }
</style>
