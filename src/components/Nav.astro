---
import { site } from '../config/site';

const currentPath = Astro.url.pathname;
const isHome = currentPath === '/';
const navigationLinks = isHome
  ? site.navigation
  : [
      { label: 'Home', href: '/' },
      { label: 'Enclosed Transport', href: '/enclosed-car-transport-quote/' },
      { label: 'Questions', href: '/vehicle-transport-questions/' },
      { label: 'Sitemap', href: '/sitemap/' },
    ];

function isActiveLink(href: string) {
  if (href.startsWith('#')) {
    return false;
  }

  if (href === '/') {
    return currentPath === '/';
  }

  return currentPath.startsWith(href);
}
---

<header class="nav-header" role="banner">
  <div class="nav-inner">
    <a href="/" class="nav-logo" aria-label={`${site.name} home`}>
      <span class="nav-logo-dot" aria-hidden="true"></span>
      <span class="nav-logo-full">{site.name}</span>
      <span class="nav-logo-short">{site.shortName}</span>
    </a>

    <nav class="nav-links" aria-label="Primary navigation">
      <ul role="list">
        {navigationLinks.map(({ label, href, external }) => (
          <li>
            <a
              href={href}
              class:list={[
                'nav-link',
                { 'nav-link--active': isActiveLink(href) },
              ]}
              aria-current={isActiveLink(href) ? 'page' : undefined}
              target={external ? '_blank' : undefined}
              rel={external ? 'noreferrer' : undefined}
            >
              {label}
            </a>
          </li>
        ))}
      </ul>
    </nav>

    <div class="nav-actions">
      <a
        href={site.primaryCta.href}
        class="nav-cta"
        target={site.primaryCta.external ? '_blank' : undefined}
        rel={site.primaryCta.external ? 'noreferrer' : undefined}
      >
        {site.primaryCta.label}
      </a>
      <button
        class="nav-burger"
        aria-label="Open navigation menu"
        aria-expanded="false"
        aria-controls="mobile-menu"
        id="nav-burger"
      >
        <span></span>
        <span></span>
        <span></span>
      </button>
    </div>

  </div>

  <div class="nav-mobile" id="mobile-menu" aria-hidden="true">
    <ul role="list">
      {navigationLinks.map(({ label, href, external }) => (
        <li>
          <a
            href={href}
            class:list={[
              'nav-mobile-link',
              { 'nav-mobile-link--active': isActiveLink(href) },
            ]}
            target={external ? '_blank' : undefined}
            rel={external ? 'noreferrer' : undefined}
          >
            {label}
          </a>
        </li>
      ))}
      <li>
        <a
          href={site.primaryCta.href}
          class="nav-mobile-cta"
          target={site.primaryCta.external ? '_blank' : undefined}
          rel={site.primaryCta.external ? 'noreferrer' : undefined}
        >
          {site.primaryCta.label}
        </a>
      </li>
    </ul>
  </div>
</header>

<style>
  .nav-header {
    position: sticky;
    top: 0;
    z-index: 100;
    background: rgba(15, 18, 21, 0.94);
    border-bottom: 1px solid var(--color-border);
    height: var(--nav-height);
    backdrop-filter: blur(12px);
  }

  .nav-inner {
    max-width: var(--container-max);
    margin: 0 auto;
    padding: 0 var(--space-6);
    height: 100%;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: var(--space-8);
  }

  /* Logo */
  .nav-logo {
    font-family: var(--font-display);
    font-weight: var(--weight-black);
    font-size: var(--text-lg);
    letter-spacing: var(--tracking-wide);
    text-transform: uppercase;
    color: var(--color-ink-primary);
    text-decoration: none;
    display: flex;
    align-items: center;
    gap: var(--space-2);
    flex-shrink: 0;
  }

  .nav-logo-short {
    display: none;
  }

  .nav-logo-dot {
    width: 7px;
    height: 7px;
    background: var(--color-accent);
    border-radius: 50%;
    flex-shrink: 0;
  }

  /* Desktop links */
  .nav-links ul {
    display: flex;
    align-items: center;
    gap: var(--space-6);
    list-style: none;
    margin: 0;
    padding: 0;
  }

  .nav-link {
    font-size: var(--text-xs);
    font-weight: var(--weight-medium);
    letter-spacing: var(--tracking-wider);
    text-transform: uppercase;
    color: var(--color-ink-secondary);
    text-decoration: none;
    transition: color var(--duration-fast) var(--ease-standard);
  }

  .nav-link:hover {
    color: var(--color-ink-primary);
  }

  .nav-link--active {
    color: var(--color-accent);
  }

  /* Actions */
  .nav-actions {
    display: flex;
    align-items: center;
    gap: var(--space-4);
    flex-shrink: 0;
  }

  .nav-cta {
    font-family: var(--font-display);
    font-weight: var(--weight-bold);
    font-size: var(--text-sm);
    letter-spacing: var(--tracking-wide);
    text-transform: uppercase;
    color: var(--color-accent-text);
    background: var(--color-accent);
    padding: var(--space-2) var(--space-4);
    border-radius: var(--radius-sm);
    text-decoration: none;
    transition: background var(--duration-fast) var(--ease-standard);
  }

  .nav-cta:hover {
    background: var(--color-accent-hover);
  }

  /* Burger */
  .nav-burger {
    display: none;
    flex-direction: column;
    justify-content: center;
    gap: 5px;
    width: 32px;
    height: 32px;
    background: transparent;
    border: none;
    cursor: pointer;
    padding: 4px;
  }

  .nav-burger span {
    display: block;
    height: 1.5px;
    background: var(--color-ink-secondary);
    border-radius: 1px;
    transition: all var(--duration-fast) var(--ease-standard);
  }

  /* Mobile menu */
  .nav-mobile {
    display: none;
    position: absolute;
    top: var(--nav-height);
    left: 0;
    right: 0;
    background: rgba(15, 18, 21, 0.98);
    border-bottom: 1px solid var(--color-border);
    padding: var(--space-4) var(--space-6) var(--space-6);
    max-height: calc(100vh - var(--nav-height));
    overflow-y: auto;
    box-shadow: 0 20px 50px rgba(0, 0, 0, 0.28);
  }

  .nav-mobile ul {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: var(--space-1);
  }

  .nav-mobile-link {
    display: block;
    font-size: var(--text-sm);
    font-weight: var(--weight-medium);
    letter-spacing: var(--tracking-wider);
    text-transform: uppercase;
    color: var(--color-ink-secondary);
    text-decoration: none;
    padding: var(--space-3) 0;
    border-bottom: 1px solid var(--color-border);
    transition: color var(--duration-fast) var(--ease-standard);
  }

  .nav-mobile-link:hover,
  .nav-mobile-link--active {
    color: var(--color-ink-primary);
  }

  .nav-mobile-cta {
    display: block;
    margin-top: var(--space-4);
    font-family: var(--font-display);
    font-weight: var(--weight-bold);
    font-size: var(--text-base);
    letter-spacing: var(--tracking-wide);
    text-transform: uppercase;
    color: var(--color-accent-text);
    background: var(--color-accent);
    padding: var(--space-3) var(--space-4);
    border-radius: var(--radius-sm);
    text-align: center;
    text-decoration: none;
  }

  /* Responsive */
  @media (max-width: 768px) {
    .nav-header {
      height: 52px;
    }

    .nav-inner {
      padding-inline: var(--space-4);
      gap: var(--space-4);
    }

    .nav-links {
      display: none;
    }

    .nav-cta {
      display: none;
    }

    .nav-burger {
      display: flex;
      width: 36px;
      height: 36px;
    }

    .nav-mobile.is-open {
      display: block;
    }

    .nav-logo {
      font-size: 0.98rem;
      letter-spacing: 0.04em;
      max-width: calc(100vw - 5.75rem);
    }
  }

  @media (max-width: 560px) {
    .nav-logo-full {
      display: none;
    }

    .nav-logo-short {
      display: inline;
    }

    .nav-mobile {
      padding: var(--space-3) var(--space-4) var(--space-5);
    }

    .nav-mobile-link {
      padding-block: var(--space-4);
    }

    .nav-mobile-cta {
      margin-top: var(--space-5);
      padding-block: 0.95rem;
    }
  }
</style>

<script>
  const burger = document.getElementById('nav-burger') as HTMLButtonElement;
  const menu   = document.getElementById('mobile-menu') as HTMLDivElement;

  burger?.addEventListener('click', () => {
    const isOpen = menu.classList.toggle('is-open');
    burger.setAttribute('aria-expanded', String(isOpen));
    menu.setAttribute('aria-hidden', String(!isOpen));
    burger.setAttribute('aria-label', isOpen ? 'Close navigation menu' : 'Open navigation menu');
  });

  // Close on outside click
  document.addEventListener('click', (e) => {
    if (!burger?.contains(e.target as Node) && !menu?.contains(e.target as Node)) {
      menu?.classList.remove('is-open');
      burger?.setAttribute('aria-expanded', 'false');
      menu?.setAttribute('aria-hidden', 'true');
    }
  });

  // Close on route change (for view transitions)
  document.addEventListener('astro:after-swap', () => {
    menu?.classList.remove('is-open');
    burger?.setAttribute('aria-expanded', 'false');
    menu?.setAttribute('aria-hidden', 'true');
  });

  menu?.querySelectorAll('a').forEach((link) => {
    link.addEventListener('click', () => {
      menu?.classList.remove('is-open');
      burger?.setAttribute('aria-expanded', 'false');
      menu?.setAttribute('aria-hidden', 'true');
      burger?.setAttribute('aria-label', 'Open navigation menu');
    });
  });
</script>
