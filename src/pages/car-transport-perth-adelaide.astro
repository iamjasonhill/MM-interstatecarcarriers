---
import SiteDocument from '../layouts/SiteDocument.astro';
import RoutePageTemplate from '../components/RoutePageTemplate.astro';
import { site, toAbsoluteUrl } from '../config/site';

const routeBenefits = [
  {
    title: 'A long-haul west-to-south corridor',
    body: 'Perth to Adelaide is a true interstate lane where professional transport removes a very long drive and gives the move a cleaner planning path from the start.',
  },
  {
    title: 'Useful for relocations and interstate purchases',
    body: 'This corridor often suits household relocations, interstate vehicle purchases, and owners who need the vehicle moved east without driving it across the Nullarbor.',
  },
  {
    title: 'A good fit for standard and specialist jobs',
    body: 'Straightforward drivable vehicles can often start with a standard quote, while non-drivable, prestige, or more sensitive jobs can still be assessed through the same contact path.',
  },
];

const whyUseTransport = [
  {
    title: 'Much less wear on the vehicle',
    body: 'A route this long can quickly add kilometres, tyre wear, and fatigue-related risk to the vehicle just to get it into South Australia.',
  },
  {
    title: 'More room to manage the move itself',
    body: 'If the transport sits inside a wider relocation or purchase, handing the vehicle over to a carrier frees up time and energy for the rest of the job.',
  },
  {
    title: 'Better than pushing through a major long-distance drive',
    body: 'On a corridor like Perth to Adelaide, the safety and fatigue side of the decision matters much more than it does on short metro-to-metro hops.',
  },
  {
    title: 'Useful when more than one vehicle is involved',
    body: 'Private moves, business fleet shifts, or purchase handovers can become much easier to coordinate when the route is planned as transport rather than self-drive.',
  },
];

const planningSignals = [
  {
    heading: 'When the standard quote is usually enough',
    copy: 'If the vehicle is drivable, the route is straightforward, and your collection and delivery conditions are normal, start with the vehicle quote wizard.',
  },
  {
    heading: 'When to contact the team first',
    copy: 'Use the contact path if the vehicle is non-drivable, the pickup point is regional or restricted, enclosed handling is likely, or the timing needs discussion before booking.',
  },
  {
    heading: 'What often affects this route most',
    copy: 'Timing windows, long-haul carrier availability, depot practicality, and the final pickup and delivery setup usually matter more than the route name alone.',
  },
];

const routeChecklist = [
  'Confirm the vehicle type, condition, and whether it is drivable.',
  'Check whether pickup and delivery are metro, depot, dealership, business, or regional points.',
  'Flag prestige, modified, oversized, or non-drivable vehicles early.',
  'Use contact instead of guessing if the move has tight timing or unusual access requirements.',
];

const iccAdvantages = [
  'A clear quote path for straightforward long-haul jobs and a contact path for anything more specialised.',
  'Support for standard vehicles, light commercials, prestige vehicles, and non-drivable transport planning.',
  'Door, depot, or handover planning depending on what best fits the route and access conditions.',
];

const corridorJobs = [
  {
    title: 'Private interstate relocations',
    detail: 'A common fit when households are moving between Western Australia and South Australia and do not want the extra burden of a very long drive.',
  },
  {
    title: 'Interstate vehicle purchases',
    detail: 'This route often suits online purchases and dealer sales where the buyer needs the vehicle brought east without collecting it personally.',
  },
  {
    title: 'Long-haul specialist jobs',
    detail: 'Because of the distance involved, this corridor is also a natural candidate for higher-touch planning when access, timing, or vehicle condition needs more discussion.',
  },
];

const pageSchemas = [
  {
    '@context': 'https://schema.org',
    '@type': 'Organization',
    '@id': toAbsoluteUrl('/#organization'),
    name: site.name,
    url: site.url,
    description: site.defaultDescription,
    logo: toAbsoluteUrl(site.seoAssets.favicon),
  },
  {
    '@context': 'https://schema.org',
    '@type': 'WebSite',
    '@id': toAbsoluteUrl('/#website'),
    url: site.url,
    name: site.name,
    description: site.defaultDescription,
    publisher: {
      '@id': toAbsoluteUrl('/#organization'),
    },
  },
  {
    '@context': 'https://schema.org',
    '@type': 'WebPage',
    '@id': toAbsoluteUrl('/car-transport-perth-adelaide/#webpage'),
    url: toAbsoluteUrl('/car-transport-perth-adelaide/'),
    name: `Car Transport Perth To Adelaide | ${site.name}`,
    description:
      'Interstate car transport guide for the Perth to Adelaide route, including when to quote online and when to contact the team first.',
    isPartOf: {
      '@id': toAbsoluteUrl('/#website'),
    },
    about: {
      '@id': toAbsoluteUrl('/#organization'),
    },
  },
  {
    '@context': 'https://schema.org',
    '@type': 'Service',
    '@id': toAbsoluteUrl('/car-transport-perth-adelaide/#service'),
    name: 'Car transport from Perth to Adelaide',
    description:
      'Interstate vehicle transport guidance for the Perth to Adelaide corridor, covering standard quotes, specialist handling, and long-haul route planning.',
    provider: {
      '@id': toAbsoluteUrl('/#organization'),
    },
    areaServed: 'Australia',
    serviceType: 'Interstate vehicle transport',
  },
];
---

<SiteDocument
  title={`Car Transport Perth To Adelaide | ${site.name}`}
  description="Interstate car transport guide for the Perth to Adelaide route, including when to quote online and when to contact the team first."
  canonicalPath="/car-transport-perth-adelaide/"
  schemas={pageSchemas}
>
  <RoutePageTemplate
    heroEyebrow="Long-haul interstate route"
    title="Car transport from Perth to Adelaide"
    intro="Perth to Adelaide is a major interstate vehicle corridor where professional transport can be a much cleaner option than driving the route yourself. For relocations, interstate purchases, and long-haul handovers, it often makes more sense to move the vehicle with a carrier than to add a very long road trip to the move."
    panelRouteTitle="Perth to Adelaide"
    panelRouteCopy="Long-haul west-to-south corridor with standard vehicle moves, specialist handling, and interstate purchase-driven demand."
    panelBestStep="Quote online for standard long-haul jobs"
    panelUseContact="Regional access, timing, or specialist handling needs discussion"
    bridgeHeading="On a route this long, the planning matters almost as much as the route itself."
    bridgeCopy="Perth to Adelaide is usually less about whether the move can happen and more about whether the vehicle, the access conditions, and the timing fit a standard booking path or need a more careful conversation first."
    benefitsHeading="Three useful things about the Perth to Adelaide lane"
    benefits={routeBenefits}
    whyHeading="Why people use car transport from Perth to Adelaide"
    whyLeadTitle="Most people book this lane to avoid a very long interstate drive"
    whyLeadBody="For long-haul relocations, vehicle purchases, and handovers, the biggest advantage is usually straightforward: you do not need to spend days on the road, organise fuel stops and accommodation, and add major distance to the vehicle just to get it east."
    corridorNoteTitle="Why this lane needs a little more planning than short east-coast corridors"
    corridorNoteBody="Perth to Adelaide usually involves a bigger timing window, more long-haul route planning, and a greater chance that depot or handover practicality matters to the booking."
    whyCards={whyUseTransport}
    planningHeading="Use the route properly, not just the route name."
    planningIntro="On a route like Perth to Adelaide, the smartest next step depends less on the city pair itself and more on the vehicle, the pickup and delivery setup, and how fixed the timing really is."
    planningSignals={planningSignals}
    advantageHeading="The kinds of jobs that most often sit on this corridor"
    advantageIntro="This is where the route-specific logic matters. Perth to Adelaide is not just a long line across the map. It is a corridor that regularly suits relocations, interstate purchases, and longer-haul jobs that benefit from cleaner planning."
    corridorJobs={corridorJobs}
    advantages={iccAdvantages}
    checklistHeading="Have the route details clear before you start."
    checklistIntro="The clearer the route, access, and vehicle details are up front, the easier it is to tell whether a standard quote is enough or whether this move should go straight to the team."
    checklist={routeChecklist}
    ctaHeading="Ready to quote Perth to Adelaide vehicle transport?"
    ctaSub="Start with the vehicle quote if the job is straightforward, or use the contact path if the route, access, or vehicle handling needs a more detailed long-haul discussion first."
  />
</SiteDocument>
