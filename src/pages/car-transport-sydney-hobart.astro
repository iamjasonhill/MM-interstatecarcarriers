---
import SiteDocument from '../layouts/SiteDocument.astro';
import RoutePageTemplate from '../components/RoutePageTemplate.astro';
import { site, toAbsoluteUrl } from '../config/site';

const routeBenefits = [
  {
    title: 'A corridor with a Tasmania leg',
    body: 'Sydney to Hobart is not just another mainland city pair. The Tasmania side of the move usually makes timing, handover details, and route fit more important to confirm up front.',
  },
  {
    title: 'Useful for relocations and interstate purchases',
    body: 'This corridor often suits household moves, interstate vehicle purchases, and owners who want the vehicle brought south without taking on the full trip personally.',
  },
  {
    title: 'A stronger fit for cleaner planning',
    body: 'Because the route has more moving parts than a simple mainland capital run, it is a good example of why quote and contact pathways should stay separate and deliberate.',
  },
];

const whyUseTransport = [
  {
    title: 'Less wear on the vehicle',
    body: 'Transport keeps unnecessary distance off the odometer and avoids pushing the vehicle through a much more involved interstate trip.',
  },
  {
    title: 'More room to manage the move',
    body: 'If the route sits inside a wider relocation or purchase, handing the vehicle to a carrier frees up time for everything else around the move.',
  },
  {
    title: 'Better than forcing the whole trip yourself',
    body: 'On a route like Sydney to Hobart, the point is often not speed but cleaner coordination, less fatigue, and a simpler handover from start to finish.',
  },
  {
    title: 'Useful when the timing matters',
    body: 'Moves involving Tasmania often benefit from discussing timing and route fit clearly rather than assuming a standard mainland lane works the same way.',
  },
];

const planningSignals = [
  {
    heading: 'When the standard quote is usually enough',
    copy: 'If the vehicle is drivable, the move is straightforward, and the collection and delivery conditions are normal, start with the vehicle quote wizard.',
  },
  {
    heading: 'When to contact the team first',
    copy: 'Use the contact path if the vehicle is non-drivable, access is tricky, enclosed handling is likely, or the move needs a more careful timing discussion before booking.',
  },
  {
    heading: 'What often affects this route most',
    copy: 'Collection and delivery practicality, timing windows, and the extra planning around a Tasmania route usually matter more here than on a standard mainland corridor.',
  },
];

const routeChecklist = [
  'Confirm the vehicle condition and whether it is fully drivable.',
  'Have the collection and delivery details clear before you quote.',
  'Flag prestige, modified, oversized, or non-drivable vehicles early.',
  'Use contact if the timing, access, or handover conditions need more discussion than a standard route.',
];

const iccAdvantages = [
  'A clean quote path for straightforward jobs and a contact path for routes that need more coordination.',
  'Support for standard vehicles, prestige moves, and specialist handling where the route demands it.',
  'Planning options that suit home, depot, and handover-based transport paths depending on the move.',
];

const corridorJobs = [
  {
    title: 'Interstate relocation moves',
    detail: 'A common fit when households are moving to Tasmania and do not want the vehicle trip to become another major project inside the move.',
  },
  {
    title: 'Vehicle purchases and handovers',
    detail: 'This corridor often suits online purchases and dealer handovers where the buyer wants a cleaner delivery path into Hobart.',
  },
  {
    title: 'Higher-touch planning jobs',
    detail: 'Because the route is more specialised than a simple mainland lane, it is also a natural candidate for contact-first transport planning when the timing or handover needs discussion.',
  },
];

const pageSchemas = [
  {
    '@context': 'https://schema.org',
    '@type': 'Organization',
    '@id': toAbsoluteUrl('/#organization'),
    name: site.name,
    url: site.url,
    description: site.defaultDescription,
    logo: toAbsoluteUrl(site.seoAssets.favicon),
  },
  {
    '@context': 'https://schema.org',
    '@type': 'WebSite',
    '@id': toAbsoluteUrl('/#website'),
    url: site.url,
    name: site.name,
    description: site.defaultDescription,
    publisher: {
      '@id': toAbsoluteUrl('/#organization'),
    },
  },
  {
    '@context': 'https://schema.org',
    '@type': 'WebPage',
    '@id': toAbsoluteUrl('/car-transport-sydney-hobart/#webpage'),
    url: toAbsoluteUrl('/car-transport-sydney-hobart/'),
    name: `Car Transport Sydney To Hobart | ${site.name}`,
    description:
      'Interstate car transport guide for the Sydney to Hobart route, including when to quote online and when to contact the team first.',
    isPartOf: {
      '@id': toAbsoluteUrl('/#website'),
    },
    about: {
      '@id': toAbsoluteUrl('/#organization'),
    },
  },
  {
    '@context': 'https://schema.org',
    '@type': 'Service',
    '@id': toAbsoluteUrl('/car-transport-sydney-hobart/#service'),
    name: 'Car transport from Sydney to Hobart',
    description:
      'Interstate vehicle transport guidance for the Sydney to Hobart corridor, covering standard quotes, specialist handling, and route planning.',
    provider: {
      '@id': toAbsoluteUrl('/#organization'),
    },
    areaServed: 'Australia',
    serviceType: 'Interstate vehicle transport',
  },
];
---

<SiteDocument
  title={`Car Transport Sydney To Hobart | ${site.name}`}
  description="Interstate car transport guide for the Sydney to Hobart route, including when to quote online and when to contact the team first."
  canonicalPath="/car-transport-sydney-hobart/"
  schemas={pageSchemas}
>
  <RoutePageTemplate
    heroEyebrow="Specialist interstate route"
    title="Car transport from Sydney to Hobart"
    intro="Sydney to Hobart is a route where professional vehicle transport can make the move much cleaner than trying to handle the whole journey yourself. For relocations, interstate purchases, and Tasmania-bound handovers, the real value is often in better coordination, less fatigue, and a clearer transport path from the start."
    panelRouteTitle="Sydney to Hobart"
    panelRouteCopy="Interstate route with a Tasmania leg, specialist timing considerations, and standard or higher-touch vehicle movements."
    panelBestStep="Quote online for straightforward jobs"
    panelUseContact="Timing, route fit, or specialist handling needs discussion"
    bridgeHeading="A Tasmania route usually needs clearer planning than a standard mainland lane."
    bridgeCopy="On a route like Sydney to Hobart, the main question is usually not whether the move can happen. It is whether the vehicle, the route setup, and the timing fit a standard booking path or need a more careful conversation first."
    benefitsHeading="Three useful things about the Sydney to Hobart lane"
    benefits={routeBenefits}
    whyHeading="Why people use car transport from Sydney to Hobart"
    whyLeadTitle="Most people book this lane to avoid turning the vehicle move into its own project"
    whyLeadBody="For relocations, purchases, and handovers into Tasmania, the biggest advantage is often simple: professional transport keeps the vehicle move organised and avoids adding a far more involved interstate trip to everything else already happening."
    corridorNoteTitle="Why this route needs more care than a simple mainland capital pair"
    corridorNoteBody="Sydney to Hobart usually benefits from clearer handover planning, more realistic timing expectations, and a stronger distinction between standard quote jobs and contact-first jobs."
    whyCards={whyUseTransport}
    planningHeading="Use the route properly, not just the route name."
    planningIntro="On a route like Sydney to Hobart, the smartest next step depends less on the city pair itself and more on the vehicle, the handover conditions, and how much discussion the move needs before booking."
    planningSignals={planningSignals}
    advantageHeading="The kinds of jobs that most often sit on this corridor"
    advantageIntro="This is where the route-specific logic matters most. Sydney to Hobart is not just another interstate lane. It is a route that regularly suits relocation, purchase, and higher-touch transport planning where cleaner coordination matters."
    corridorJobs={corridorJobs}
    advantages={iccAdvantages}
    checklistHeading="Have the route details clear before you start."
    checklistIntro="The clearer the route, vehicle, and handover details are up front, the easier it is to tell whether a standard quote is enough or whether this move should go straight to the team."
    checklist={routeChecklist}
    ctaHeading="Ready to quote Sydney to Hobart vehicle transport?"
    ctaSub="Start with the vehicle quote if the job is straightforward, or use the contact path if the route, timing, or vehicle handling needs a more detailed conversation first."
  />
</SiteDocument>
