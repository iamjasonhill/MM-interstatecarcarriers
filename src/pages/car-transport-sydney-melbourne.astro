---
import SiteDocument from '../layouts/SiteDocument.astro';
import { site, toAbsoluteUrl } from '../config/site';

const routeBenefits = [
  {
    title: 'A high-frequency corridor',
    body: 'Sydney to Melbourne is one of the busiest interstate vehicle lanes in the country, which usually means stronger carrier availability than lower-volume routes.',
  },
  {
    title: 'Useful for relocations and purchases',
    body: 'This corridor suits private moves, online vehicle purchases, dealer transfers, and anyone who would rather avoid the long drive south.',
  },
  {
    title: 'Flexible enough for standard or specialist handling',
    body: 'Many everyday vehicles can move on a standard lane, while prestige, non-drivable, or more sensitive jobs can still be assessed through the same quote and contact flow.',
  },
];

const routeWhyLead = {
  title: 'Most people book this lane to avoid the long Sydney-to-Melbourne drive',
  body: 'For relocations, vehicle purchases, and handovers, the biggest advantage is usually simple: you do not need to spend a full day on the road, organise fuel stops, and add more kilometres to the car just to get it south.',
};

const whyUseTransport = [
  {
    title: 'Less wear on the vehicle',
    body: 'Keeping unnecessary kilometres off the odometer helps reduce wear on tyres, mechanicals, and overall vehicle condition.',
  },
  {
    title: 'More time for the rest of the move',
    body: 'If you are relocating, buying a car, or organising a handover, transport lets you focus on everything else around the move.',
  },
  {
    title: 'Safer than pushing through a long drive',
    body: 'Fatigue, traffic conditions, and unexpected breakdowns all become part of the risk when you decide to drive the route yourself.',
  },
  {
    title: 'Useful for multi-vehicle or dealer jobs',
    body: 'This corridor often carries dealer transfers, business moves, and jobs where more than one vehicle needs to be coordinated cleanly.',
  },
];

const planningSignals = [
  {
    heading: 'When the standard quote is usually enough',
    copy: 'If the vehicle is drivable, the route is straightforward, and your collection and delivery conditions are relatively normal, start with the vehicle quote wizard.',
  },
  {
    heading: 'When to contact the team first',
    copy: 'Use the contact path if the vehicle is non-drivable, access is tricky, enclosed handling is likely, or the timing needs more discussion before booking.',
  },
  {
    heading: 'What often affects this route most',
    copy: 'Timing windows, carrier availability, and whether the job is depot, home delivery, or something more specialised usually matter more than generic route copy.',
  },
];

const routeChecklist = [
  'Have the vehicle type and condition ready before you quote.',
  'Know whether pickup and delivery are depot, residential, dealership, or business locations.',
  'Flag non-drivable, modified, prestige, or presentation-sensitive vehicles early.',
  'Use contact instead of guessing if the timing window is tighter than usual.',
];

const iccAdvantages = [
  'Door-to-door or depot-style planning depending on what suits the move best.',
  'Vehicle types ranging from standard sedans to light commercials and non-drivable vehicles.',
  'A cleaner quote path for straightforward jobs and a contact path for anything that needs more discussion.',
];

const corridorJobs = [
  {
    title: 'Private relocation moves',
    detail: 'A common fit when households are relocating between the two largest east-coast cities and do not want the extra driving burden.',
  },
  {
    title: 'Interstate vehicle purchases',
    detail: 'This route often suits online purchases and dealer sales where the buyer needs the car brought south without making the trip themselves.',
  },
  {
    title: 'Dealer and business handovers',
    detail: 'Because the corridor is active, dealer transfers and business jobs can often be planned more cleanly than on lower-volume regional lanes.',
  },
];

const pageSchemas = [
  {
    '@context': 'https://schema.org',
    '@type': 'Organization',
    '@id': toAbsoluteUrl('/#organization'),
    name: site.name,
    url: site.url,
    description: site.defaultDescription,
    logo: toAbsoluteUrl(site.seoAssets.favicon),
  },
  {
    '@context': 'https://schema.org',
    '@type': 'WebSite',
    '@id': toAbsoluteUrl('/#website'),
    url: site.url,
    name: site.name,
    description: site.defaultDescription,
    publisher: {
      '@id': toAbsoluteUrl('/#organization'),
    },
  },
  {
    '@context': 'https://schema.org',
    '@type': 'WebPage',
    '@id': toAbsoluteUrl('/car-transport-sydney-melbourne/#webpage'),
    url: toAbsoluteUrl('/car-transport-sydney-melbourne/'),
    name: `Car Transport Sydney To Melbourne | ${site.name}`,
    description:
      'Interstate car transport guide for the Sydney to Melbourne route, including when to quote online and when to contact the team first.',
    isPartOf: {
      '@id': toAbsoluteUrl('/#website'),
    },
    about: {
      '@id': toAbsoluteUrl('/#organization'),
    },
  },
  {
    '@context': 'https://schema.org',
    '@type': 'Service',
    '@id': toAbsoluteUrl('/car-transport-sydney-melbourne/#service'),
    name: 'Car transport from Sydney to Melbourne',
    description:
      'Interstate vehicle transport guidance for the Sydney to Melbourne corridor, covering standard quotes, specialist handling, and route planning.',
    provider: {
      '@id': toAbsoluteUrl('/#organization'),
    },
    areaServed: 'Australia',
    serviceType: 'Interstate vehicle transport',
  },
];
---

<SiteDocument
  title={`Car Transport Sydney To Melbourne | ${site.name}`}
  description="Interstate car transport guide for the Sydney to Melbourne route, including when to quote online and when to contact the team first."
  canonicalPath="/car-transport-sydney-melbourne/"
  schemas={pageSchemas}
>
  <section class="route-hero">
    <div class="container route-hero-inner">
      <div class="route-copy">
        <span class="section-rule" aria-hidden="true"></span>
        <p class="eyebrow">High-frequency interstate route</p>
        <h1 class="display-lg route-title">Car transport from Sydney to Melbourne</h1>
        <p class="route-intro">
          Sydney to Melbourne is one of the busiest interstate vehicle corridors in Australia.
          Whether you are relocating, buying a car from interstate, or simply do not want to make
          the long drive yourself, professional vehicle transport can be the cleaner and less
          stressful option.
        </p>
        <div class="route-actions">
          <a href={site.primaryCta.href} class="btn btn--primary">Get a vehicle quote</a>
          <a href={site.secondaryCta.href} class="btn btn--ghost">Contact the quote team</a>
        </div>
      </div>

      <div class="route-panel" aria-hidden="true">
        <div class="route-panel-card">
          <div class="route-panel-top">
            <p class="route-panel-label">Route snapshot</p>
            <span>Core corridor</span>
          </div>
          <div class="route-lane-card">
            <strong>Sydney to Melbourne</strong>
            <p>High-frequency east-coast vehicle demand with standard, specialist, and purchase-driven movements.</p>
          </div>
          <div class="route-panel-grid">
            <div>
              <span>Best first step</span>
              <p>Quote online for standard jobs</p>
            </div>
            <div>
              <span>Use contact when</span>
              <p>Timing or handling needs discussion</p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="route-bridge">
    <div class="container route-bridge-inner">
      <div>
        <p class="eyebrow">Why this route matters</p>
        <h2 class="display-md route-bridge-heading">A busy corridor usually means clearer quoting and better route fit.</h2>
      </div>
      <p class="route-bridge-copy">
        On a lane like Sydney to Melbourne, the real question is usually not whether the move can be
        done. It is whether the vehicle, the timing, and the collection conditions fit a standard
        booking path or need a more careful conversation first.
      </p>
    </div>
  </section>

  <section class="section route-benefits" aria-labelledby="route-benefits-heading">
    <div class="container">
      <div class="route-benefits-head">
        <p class="eyebrow">What makes this corridor different</p>
        <h2 id="route-benefits-heading" class="display-md">Three useful things about the Sydney to Melbourne lane</h2>
      </div>

      <div class="route-benefits-grid">
        {routeBenefits.map(({ title, body }) => (
          <article class="route-benefit-card">
            <h3>{title}</h3>
            <p>{body}</p>
          </article>
        ))}
      </div>
    </div>
  </section>

  <section class="section route-why" aria-labelledby="route-why-heading">
    <div class="container">
      <div class="route-why-head">
        <p class="eyebrow">Why use a transport company</p>
        <h2 id="route-why-heading" class="display-md">Why people use car transport from Sydney to Melbourne</h2>
      </div>

      <div class="route-why-layout">
        <article class="route-why-lead">
          <p class="route-why-label">Lead reason</p>
          <h3>{routeWhyLead.title}</h3>
          <p>{routeWhyLead.body}</p>
        </article>

        <aside class="route-why-note">
          <p class="route-why-label">Corridor note</p>
          <h3>Why this lane is easier to plan than lower-volume routes</h3>
          <p>
            Sydney to Melbourne usually benefits from stronger demand, clearer handover options, and
            more familiar metro pickup and delivery conditions than thinner regional corridors.
          </p>
        </aside>
      </div>

      <div class="route-why-grid">
        {whyUseTransport.map(({ title, body }) => (
          <article class="route-why-card">
            <h3>{title}</h3>
            <p>{body}</p>
          </article>
        ))}
      </div>
    </div>
  </section>

  <section class="route-planning">
    <div class="container">
      <div class="route-planning-head">
        <p class="eyebrow">Booking logic</p>
        <h2 class="display-md route-planning-heading">Use the route properly, not just the route name.</h2>
        <p class="route-planning-intro">
          On a route like Sydney to Melbourne, the smartest next step depends less on the city pair
          itself and more on the vehicle, the handover conditions, and how fixed the timing really is.
        </p>
      </div>

      <div class="route-planning-grid">
        {planningSignals.map(({ heading, copy }) => (
          <article class="route-planning-card">
            <h3>{heading}</h3>
            <p>{copy}</p>
          </article>
        ))}
      </div>
    </div>
  </section>

  <section class="route-advantage">
    <div class="container route-advantage-inner">
      <div>
        <p class="eyebrow">Typical booking fit</p>
        <h2 class="display-md route-advantage-heading">The kinds of jobs that most often sit on this corridor</h2>
      </div>

      <div class="route-advantage-panel">
        <p class="route-advantage-intro">
          This is where the route-specific logic comes back in. Sydney to Melbourne is not just a
          named lane on a map. It is a corridor that regularly carries a recognisable mix of
          relocation, purchase, and handover jobs.
        </p>
        <div class="route-advantage-jobs">
          {corridorJobs.map(({ title, detail }) => (
            <article class="route-advantage-job">
              <h3>{title}</h3>
              <p>{detail}</p>
            </article>
          ))}
        </div>
        <ul class="route-advantage-list" role="list">
          {iccAdvantages.map((item) => <li>{item}</li>)}
        </ul>
      </div>
    </div>
  </section>

  <section class="route-checklist">
    <div class="container route-checklist-inner">
      <div class="route-checklist-copy">
        <p class="eyebrow">Before you quote</p>
        <h2 class="display-md route-checklist-heading">Have the route details clear before you start.</h2>
        <p class="route-checklist-intro">
          The cleaner the route and vehicle details are up front, the easier it is to tell whether a
          standard quote is enough or whether this job should go straight to the team.
        </p>
      </div>

      <div class="route-checklist-panel">
        <p class="route-checklist-label">Quick checklist</p>
        <ul class="route-checklist-list" role="list">
          {routeChecklist.map((item) => <li>{item}</li>)}
        </ul>
      </div>
    </div>
  </section>

  <section class="cta-band cta-band--route" id="contact" aria-labelledby="route-cta-heading">
    <div class="container cta-inner">
      <div>
        <h2 id="route-cta-heading" class="display-md cta-heading">Ready to quote Sydney to Melbourne vehicle transport?</h2>
        <p class="cta-sub">
          Start with the vehicle quote if the job is straightforward, or use the contact path if the
          vehicle, access, or timing needs a more detailed route discussion first.
        </p>
      </div>
      <div class="cta-actions">
        <a href={site.primaryCta.href} class="btn btn--primary btn--lg">Get a vehicle quote</a>
        <a href={site.secondaryCta.href} class="btn btn--ghost btn--lg">Contact the quote team</a>
      </div>
    </div>
  </section>
</SiteDocument>

<style>
  .route-hero {
    background:
      radial-gradient(circle at top right, rgba(59, 143, 214, 0.16), transparent 22rem),
      linear-gradient(180deg, #11161d 0%, #0c0f13 100%);
    border-bottom: 1px solid var(--color-border);
  }

  .route-hero-inner {
    display: grid;
    grid-template-columns: minmax(0, 1.05fr) minmax(20rem, 0.95fr);
    gap: var(--space-12);
    align-items: center;
    padding-block: var(--space-24) var(--space-26);
  }

  .route-copy {
    max-width: 46rem;
  }

  .route-title {
    max-width: 11ch;
    margin-bottom: var(--space-6);
  }

  .route-intro {
    max-width: 41rem;
    color: var(--color-ink-secondary);
    font-size: clamp(1rem, 0.95rem + 0.15vw, 1.1rem);
    line-height: 1.75;
    margin: 0 0 var(--space-10);
  }

  .route-actions {
    display: flex;
    gap: var(--space-5);
    flex-wrap: wrap;
  }

  .route-panel-card {
    padding: var(--space-8);
    border-radius: calc(var(--radius-lg) + 0.2rem);
    border: 1px solid rgba(255, 255, 255, 0.08);
    background:
      linear-gradient(180deg, rgba(255, 255, 255, 0.05), rgba(255, 255, 255, 0.02)),
      rgba(9, 13, 18, 0.92);
    box-shadow: 0 24px 60px rgba(0, 0, 0, 0.25);
  }

  .route-panel-top {
    display: flex;
    justify-content: space-between;
    gap: var(--space-3);
    align-items: center;
    margin-bottom: var(--space-5);
  }

  .route-panel-label,
  .route-checklist-label {
    margin: 0;
    font-size: var(--text-xs);
    text-transform: uppercase;
    letter-spacing: var(--tracking-widest);
    color: var(--color-accent);
  }

  .route-panel-top span {
    font-size: var(--text-xs);
    text-transform: uppercase;
    letter-spacing: var(--tracking-widest);
    color: var(--color-ink-muted);
  }

  .route-lane-card {
    padding: var(--space-5);
    border-radius: var(--radius-lg);
    background: rgba(255, 255, 255, 0.03);
    border: 1px solid rgba(255, 255, 255, 0.06);
    margin-bottom: var(--space-5);
  }

  .route-lane-card strong {
    display: block;
    margin-bottom: var(--space-3);
    font-family: var(--font-display);
    font-size: clamp(1.6rem, 1.45rem + 0.45vw, 2rem);
    letter-spacing: var(--tracking-wide);
    text-transform: uppercase;
    color: white;
  }

  .route-lane-card p,
  .route-panel-grid p {
    margin: 0;
    color: var(--color-ink-secondary);
    line-height: 1.75;
  }

  .route-panel-grid {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: var(--space-4);
  }

  .route-panel-grid span {
    display: block;
    margin-bottom: var(--space-2);
    font-size: var(--text-xs);
    text-transform: uppercase;
    letter-spacing: var(--tracking-widest);
    color: #9fcbef;
  }

  .route-bridge {
    background:
      radial-gradient(circle at top right, rgba(59, 143, 214, 0.08), transparent 20rem),
      #F2FBF5;
    border-top: 1px solid rgba(15, 24, 34, 0.08);
    border-bottom: 1px solid rgba(15, 24, 34, 0.08);
  }

  .route-planning {
    background:
      radial-gradient(circle at top right, rgba(59, 143, 214, 0.06), transparent 20rem),
      linear-gradient(180deg, #fbfdfa 0%, #f6faf7 100%);
    border-bottom: 1px solid rgba(15, 24, 34, 0.08);
  }

  .route-bridge-inner,
  .route-checklist-inner {
    display: grid;
    grid-template-columns: minmax(0, 1fr) minmax(18rem, 0.95fr);
    gap: var(--space-10);
    align-items: start;
    padding-block: var(--space-20);
  }

  .route-bridge-heading,
  .route-planning-heading,
  .route-checklist-heading {
    color: #111823;
    max-width: 16ch;
    margin-bottom: var(--space-4);
  }

  .route-planning-head {
    max-width: 44rem;
    margin-bottom: var(--space-12);
  }

  .route-planning-intro {
    margin: 0;
    color: #4b5968;
    line-height: 1.8;
    max-width: 38rem;
  }

  .route-bridge-copy,
  .route-checklist-intro {
    margin: 0;
    color: #4b5968;
    line-height: 1.8;
    max-width: 35rem;
  }

  .route-benefits {
    background: linear-gradient(180deg, #10151c 0%, #0d1117 100%);
    border-bottom: 1px solid var(--color-border);
  }

  .route-benefits-head {
    margin-bottom: var(--space-12);
  }

  .route-benefits-grid,
  .route-planning-grid {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: var(--space-6);
  }

  .route-why-grid {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: var(--space-6);
  }

  .route-benefit-card,
  .route-why-card,
  .route-planning-card {
    padding: var(--space-8);
    border-radius: var(--radius-lg);
  }

  .route-benefit-card {
    border: 1px solid rgba(255, 255, 255, 0.08);
    background:
      linear-gradient(180deg, rgba(255, 255, 255, 0.03), transparent),
      var(--color-surface-raised);
  }

  .route-why {
    background:
      radial-gradient(circle at top right, rgba(59, 143, 214, 0.08), transparent 20rem),
      #F2FBF5;
    border-bottom: 1px solid rgba(15, 24, 34, 0.08);
  }

  .route-why-head {
    margin-bottom: var(--space-12);
  }

  .route-why .eyebrow {
    color: #356fa3;
  }

  .route-why-head .display-md {
    color: #111823;
  }

  .route-why-layout {
    display: grid;
    grid-template-columns: minmax(0, 1.1fr) minmax(18rem, 0.9fr);
    gap: var(--space-6);
    margin-bottom: var(--space-6);
  }

  .route-why-lead,
  .route-why-note {
    padding: var(--space-8);
    border-radius: calc(var(--radius-lg) + 0.15rem);
    border: 1px solid rgba(15, 24, 34, 0.08);
    background: rgba(255, 255, 255, 0.72);
    box-shadow: 0 18px 40px rgba(15, 24, 34, 0.08);
  }

  .route-why-label {
    margin: 0 0 var(--space-3);
    font-size: var(--text-xs);
    text-transform: uppercase;
    letter-spacing: var(--tracking-widest);
    color: #356fa3;
  }

  .route-why-lead h3,
  .route-why-note h3 {
    margin: 0 0 var(--space-4);
    font-family: var(--font-display);
    font-size: clamp(1.55rem, 1.35rem + 0.45vw, 2rem);
    letter-spacing: var(--tracking-wide);
    text-transform: uppercase;
    color: #111823;
    max-width: 18ch;
  }

  .route-why-lead p:last-child,
  .route-why-note p:last-child {
    margin: 0;
    color: #4b5968;
    line-height: 1.85;
  }

  .route-why-card {
    border: 1px solid rgba(15, 24, 34, 0.08);
    background: rgba(255, 255, 255, 0.72);
    box-shadow: 0 18px 40px rgba(15, 24, 34, 0.08);
  }

  .route-planning-card,
  .route-checklist-panel,
  .route-advantage-panel {
    border: 1px solid rgba(15, 24, 34, 0.08);
    background: rgba(255, 255, 255, 0.72);
    box-shadow: 0 18px 40px rgba(15, 24, 34, 0.08);
  }

  .route-benefit-card h3,
  .route-why-card h3,
  .route-planning-card h3 {
    margin: 0 0 var(--space-4);
    font-family: var(--font-display);
    font-size: clamp(1.25rem, 1.1rem + 0.35vw, 1.6rem);
    letter-spacing: var(--tracking-wide);
    text-transform: uppercase;
  }

  .route-benefit-card h3 {
    color: var(--color-ink-primary);
  }

  .route-why-card h3,
  .route-planning-card h3 {
    color: #111823;
  }

  .route-planning-card:first-child {
    grid-column: span 2;
    background:
      linear-gradient(180deg, rgba(59, 143, 214, 0.08), rgba(255, 255, 255, 0.86)),
      rgba(255, 255, 255, 0.86);
    border-color: rgba(53, 111, 163, 0.14);
  }

  .route-planning-card:first-child h3 {
    font-size: clamp(1.45rem, 1.2rem + 0.45vw, 1.9rem);
    max-width: 22ch;
  }

  .route-planning-card:first-child p {
    max-width: 42rem;
  }

  .route-benefit-card p {
    margin: 0;
    color: var(--color-ink-secondary);
    line-height: 1.8;
  }

  .route-why-card p,
  .route-planning-card p {
    margin: 0;
    color: #4b5968;
    line-height: 1.8;
  }

  .route-advantage {
    background: linear-gradient(180deg, #10151c 0%, #0d1117 100%);
    border-bottom: 1px solid var(--color-border);
  }

  .route-advantage-inner {
    display: grid;
    grid-template-columns: minmax(0, 0.9fr) minmax(0, 1.1fr);
    gap: var(--space-10);
    align-items: start;
    padding-block: var(--space-20);
  }

  .route-advantage-heading {
    max-width: 15ch;
  }

  .route-advantage-panel {
    padding: var(--space-8);
    border-radius: calc(var(--radius-lg) + 0.15rem);
  }

  .route-advantage-jobs {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: var(--space-4);
    margin-bottom: var(--space-6);
  }

  .route-advantage-job {
    padding: var(--space-5);
    border-radius: var(--radius-base);
    background: rgba(15, 24, 34, 0.04);
    border: 1px solid rgba(15, 24, 34, 0.08);
  }

  .route-advantage-job h3 {
    margin: 0 0 var(--space-3);
    font-family: var(--font-display);
    font-size: var(--text-lg);
    letter-spacing: var(--tracking-wide);
    text-transform: uppercase;
    color: #111823;
  }

  .route-advantage-job p {
    margin: 0;
    color: #4b5968;
    line-height: 1.75;
  }

  .route-advantage-intro {
    margin: 0 0 var(--space-5);
    color: #4b5968;
    line-height: 1.8;
  }

  .route-advantage-list {
    display: grid;
    gap: var(--space-4);
    margin: 0;
    padding: 0;
  }

  .route-advantage-list li {
    position: relative;
    padding-left: var(--space-5);
    color: #4b5968;
    line-height: 1.8;
  }

  .route-advantage-list li::before {
    content: "";
    position: absolute;
    top: 0.7rem;
    left: 0;
    width: 0.45rem;
    height: 0.45rem;
    border-radius: 999px;
    background: var(--color-accent);
  }

  .route-checklist {
    background: #F2FBF5;
    border-bottom: 1px solid rgba(15, 24, 34, 0.08);
  }

  .route-checklist-panel {
    padding: var(--space-8);
