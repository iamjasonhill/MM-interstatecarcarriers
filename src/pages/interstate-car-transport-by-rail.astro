---
import SiteDocument from '../layouts/SiteDocument.astro';
import { site, toAbsoluteUrl } from '../config/site';

const comparisonPoints = [
  {
    title: 'Rail can make sense on long-haul corridors',
    body: 'Train transport can be attractive on some long-distance moves, especially when the route lines up with major rail-served centres and price is a key factor.',
  },
  {
    title: 'Rail is usually less flexible than truck transport',
    body: 'The tradeoff is that rail often depends on station access, transfer points, and more fixed collection arrangements than a road-based carrier.',
  },
  {
    title: 'The cheapest rail option is not always the easiest move',
    body: 'A lower transport price can lose its advantage if the vehicle still needs extra transfers, local collection, or more handling at each end of the trip.',
  },
];

const factors = [
  {
    heading: 'Price',
    copy: 'Rail can be cost-effective on some long routes, but the real comparison should include any extra transfer or station collection costs at either end.',
  },
  {
    heading: 'Access and collection',
    copy: 'Truck transport usually offers more route flexibility and easier access to suburbs, smaller centres, and direct delivery points.',
  },
  {
    heading: 'Timing',
    copy: 'The right decision depends on not only the quoted transit time, but also how easily the vehicle can be handed over and collected.',
  },
  {
    heading: 'Protection and conditions',
    copy: 'Always check insurance, handling conditions, and whether the vehicle type or any goods inside it create restrictions for the transport method.',
  },
];

const compareRows = [
  {
    factor: 'Best fit',
    rail: 'Longer corridors where station-based collection is workable',
    road: 'More flexible suburb-to-suburb or direct delivery moves',
  },
  {
    factor: 'Collection and delivery',
    rail: 'Often depends on stations, transfer points, or extra collection planning',
    road: 'Usually easier to line up with homes, dealerships, and more local delivery points',
  },
  {
    factor: 'Practical tradeoff',
    rail: 'Can look cheaper on paper, but may need more coordination at each end',
    road: 'Usually offers simpler handling and fewer transfer steps',
  },
];

const pageSchemas = [
  {
    '@context': 'https://schema.org',
    '@type': 'Organization',
    '@id': toAbsoluteUrl('/#organization'),
    name: site.name,
    url: site.url,
    description: site.defaultDescription,
    logo: toAbsoluteUrl(site.seoAssets.favicon),
  },
  {
    '@context': 'https://schema.org',
    '@type': 'WebSite',
    '@id': toAbsoluteUrl('/#website'),
    url: site.url,
    name: site.name,
    description: site.defaultDescription,
    publisher: {
      '@id': toAbsoluteUrl('/#organization'),
    },
  },
  {
    '@context': 'https://schema.org',
    '@type': 'WebPage',
    '@id': toAbsoluteUrl('/interstate-car-transport-by-rail/#webpage'),
    url: toAbsoluteUrl('/interstate-car-transport-by-rail/'),
    name: `Interstate Car Transport By Rail | ${site.name}`,
    description:
      'Guide to interstate car transport by rail, including when it can suit the move and what tradeoffs to compare against truck transport.',
    isPartOf: {
      '@id': toAbsoluteUrl('/#website'),
    },
    about: {
      '@id': toAbsoluteUrl('/#organization'),
    },
  },
];
---

<SiteDocument
  title={`Interstate Car Transport By Rail | ${site.name}`}
  description="Guide to interstate car transport by rail, including when it can suit the move and what tradeoffs to compare against truck transport."
  canonicalPath="/interstate-car-transport-by-rail/"
  schemas={pageSchemas}
>
  <section class="page-hero">
    <div class="container page-hero-inner">
      <span class="section-rule" aria-hidden="true"></span>
      <p class="eyebrow">Transport mode guide</p>
      <h1 class="display-lg page-title">Interstate car transport by rail</h1>
      <p class="page-intro">
        Rail can be a useful interstate vehicle transport option on the right corridor, but it is
        not automatically the best fit for every move. The real question is whether the route,
        collection points, timing, and handling requirements line up with how you need the job done.
      </p>
      <div class="page-actions">
        <a href={site.primaryCta.href} class="btn btn--primary">Get a vehicle quote</a>
        <a href={site.secondaryCta.href} class="btn btn--ghost">Contact the quote team</a>
      </div>
    </div>
  </section>

  <section class="guide-bridge">
    <div class="container guide-bridge-inner">
      <div>
        <p class="eyebrow">The main tradeoff</p>
        <h2 class="display-md guide-heading">Rail can lower cost on some long routes, but truck transport is often easier at both ends.</h2>
      </div>
      <p class="guide-copy">
        The most practical choice depends on where the vehicle starts, where it needs to end up, and
        whether direct access matters more than a lower headline price.
      </p>
    </div>
  </section>

  <section class="section comparison-section" aria-labelledby="comparison-heading">
    <div class="container">
      <div class="comparison-head">
        <p class="eyebrow">What to compare</p>
        <h2 id="comparison-heading" class="display-md">Three things rail customers should weigh up early</h2>
      </div>

      <div class="comparison-grid">
        {comparisonPoints.map(({ title, body }) => (
          <article class="comparison-card">
            <h3>{title}</h3>
            <p>{body}</p>
          </article>
        ))}
      </div>
    </div>
  </section>

  <section class="rail-compare" aria-labelledby="rail-compare-heading">
    <div class="container rail-compare-inner">
      <div>
        <p class="eyebrow">Rail vs road</p>
        <h2 id="rail-compare-heading" class="display-md rail-compare-heading">A simple way to compare rail against truck transport.</h2>
      </div>

      <div class="rail-compare-table" role="table" aria-label="Rail versus road comparison">
        {compareRows.map(({ factor, rail, road }) => (
          <div class="rail-compare-row" role="row">
            <div class="rail-compare-factor" role="cell">
              <strong>{factor}</strong>
            </div>
            <div class="rail-compare-cell" role="cell">
              <span>Rail</span>
              <p>{rail}</p>
            </div>
            <div class="rail-compare-cell" role="cell">
              <span>Road</span>
              <p>{road}</p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <section class="factors-section">
    <div class="container factors-inner">
      <div>
        <p class="eyebrow">Decision checklist</p>
        <h2 class="display-md factors-heading">Compare the move properly before choosing rail.</h2>
      </div>

      <div class="factors-grid">
        {factors.map(({ heading, copy }) => (
          <article class="factor-card">
            <h3>{heading}</h3>
            <p>{copy}</p>
          </article>
        ))}
      </div>
    </div>
  </section>

  <section class="cta-band cta-band--page" aria-labelledby="page-cta-heading">
    <div class="container cta-inner">
      <div>
        <h2 id="page-cta-heading" class="display-md cta-heading">Ready to compare rail against the best available transport lane?</h2>
        <p class="cta-sub">
          Start with the vehicle quote if the route is clear, or use the contact path if you want to
          talk through rail, truck, or collection-point tradeoffs before booking.
        </p>
      </div>
      <div class="cta-actions">
        <a href={site.primaryCta.href} class="btn btn--primary btn--lg">Get a vehicle quote</a>
        <a href={site.secondaryCta.href} class="btn btn--ghost btn--lg">Contact the quote team</a>
      </div>
    </div>
  </section>
</SiteDocument>

<style>
  .page-hero {
    background:
      radial-gradient(circle at top right, rgba(59, 143, 214, 0.16), transparent 22rem),
      linear-gradient(180deg, #11161d 0%, #0c0f13 100%);
    border-bottom: 1px solid var(--color-border);
  }

  .page-hero-inner {
    padding-block: var(--space-24);
    max-width: 54rem;
  }

  .page-title {
    max-width: 10ch;
    margin-bottom: var(--space-6);
  }

  .page-intro {
    max-width: 44rem;
    color: var(--color-ink-secondary);
    font-size: clamp(1rem, 0.95rem + 0.15vw, 1.1rem);
    line-height: 1.75;
    margin: 0 0 var(--space-10);
  }

  .page-actions {
    display: flex;
    gap: var(--space-5);
    flex-wrap: wrap;
    padding-top: var(--space-2);
  }

  .guide-bridge,
  .factors-section {
    background:
      radial-gradient(circle at top right, rgba(59, 143, 214, 0.08), transparent 20rem),
      #F2FBF5;
    border-top: 1px solid rgba(15, 24, 34, 0.08);
    border-bottom: 1px solid rgba(15, 24, 34, 0.08);
  }

  .guide-bridge-inner,
  .factors-inner {
    display: grid;
    grid-template-columns: minmax(0, 1fr) minmax(18rem, 0.9fr);
    gap: var(--space-10);
    align-items: start;
    padding-block: var(--space-20);
  }

  .guide-heading,
  .factors-heading {
    color: #111823;
    max-width: 16ch;
    margin-bottom: var(--space-4);
  }

  .guide-copy {
    margin: 0;
    color: #4b5968;
    line-height: 1.8;
    max-width: 34rem;
  }

  .comparison-section {
    background: linear-gradient(180deg, #10151c 0%, #0d1117 100%);
    border-bottom: 1px solid var(--color-border);
  }

  .comparison-head {
    margin-bottom: var(--space-12);
  }

  .comparison-grid,
  .factors-grid {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: var(--space-6);
  }

  .comparison-card,
  .factor-card {
    padding: var(--space-8);
    border-radius: var(--radius-lg);
  }

  .comparison-card {
    border: 1px solid rgba(255, 255, 255, 0.08);
    background:
      linear-gradient(180deg, rgba(255, 255, 255, 0.03), transparent),
      var(--color-surface-raised);
  }

  .factor-card {
    border: 1px solid rgba(15, 24, 34, 0.08);
    background: rgba(255, 255, 255, 0.72);
  }

  .comparison-card h3,
  .factor-card h3 {
    margin: 0 0 var(--space-4);
    font-family: var(--font-display);
    font-size: clamp(1.25rem, 1.1rem + 0.35vw, 1.6rem);
    letter-spacing: var(--tracking-wide);
    text-transform: uppercase;
  }

  .comparison-card h3 {
    color: var(--color-ink-primary);
  }

  .factor-card h3 {
    color: #111823;
  }

  .comparison-card p {
    margin: 0;
    color: var(--color-ink-secondary);
    line-height: 1.8;
  }

  .rail-compare {
    background: #F2FBF5;
    border-bottom: 1px solid rgba(15, 24, 34, 0.08);
  }

  .rail-compare-inner {
    padding-block: var(--space-20);
  }

  .rail-compare-heading {
    color: #111823;
    max-width: 15ch;
    margin-bottom: var(--space-8);
  }

  .rail-compare-table {
    display: grid;
    gap: var(--space-4);
  }

  .rail-compare-row {
    display: grid;
    grid-template-columns: minmax(10rem, 0.7fr) minmax(0, 1fr) minmax(0, 1fr);
    gap: var(--space-4);
    padding: var(--space-5);
    border-radius: var(--radius-lg);
    border: 1px solid rgba(15, 24, 34, 0.08);
    background: rgba(255, 255, 255, 0.72);
  }

  .rail-compare-factor strong {
    display: block;
    color: #111823;
    font-family: var(--font-display);
    font-size: var(--text-lg);
    letter-spacing: var(--tracking-wide);
    text-transform: uppercase;
  }

  .rail-compare-cell span {
    display: block;
    margin-bottom: var(--space-2);
    font-size: var(--text-xs);
    text-transform: uppercase;
    letter-spacing: var(--tracking-widest);
    color: #356fa3;
  }

  .rail-compare-cell p {
    margin: 0;
    color: #4b5968;
    line-height: 1.8;
  }

  .factor-card p {
    margin: 0;
    color: #4b5968;
    line-height: 1.8;
  }

  .cta-band--page {
    border-top: 0;
    padding-block: var(--space-20);
  }

  .cta-band--page .cta-inner {
    padding-block: var(--space-8);
  }

  .cta-band--page .cta-heading {
    margin-bottom: var(--space-5);
  }

  .cta-band--page .cta-sub {
    max-width: 42rem;
  }

  .cta-band--page .cta-actions {
    margin-top: var(--space-8);
  }

  @media (max-width: 960px) {
    .guide-bridge-inner,
    .comparison-grid,
    .rail-compare-row,
    .factors-inner,
    .factors-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
