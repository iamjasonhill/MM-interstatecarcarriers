{
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "Content-Security-Policy",
          "value": "default-src 'self' https: data: blob:; script-src 'self' 'unsafe-inline' https:; style-src 'self' 'unsafe-inline' https:; img-src 'self' data: https:; font-src 'self' data: https:; connect-src 'self' https:; frame-src 'self' https:; object-src 'none'; base-uri 'self'; form-action 'self' https:;"
        },
        {
          "key": "X-Content-Type-Options",
          "value": "nosniff"
        },
        {
          "key": "Referrer-Policy",
          "value": "strict-origin-when-cross-origin"
        },
        {
          "key": "Permissions-Policy",
          "value": "camera=(), microphone=(), geolocation=(), interest-cohort=()"
        }
      ]
    }
  ],
  "redirects": [
    {
      "source": "/sitemap_index.xml",
      "destination": "/sitemap-index.xml",
      "permanent": true
    },
    {
      "source": "/contact",
      "destination": "https://quoting.interstatecarcarriers.com.au/contact",
      "permanent": true
    },
    {
      "source": "/contact/",
      "destination": "https://quoting.interstatecarcarriers.com.au/contact",
      "permanent": true
    },
    {
      "source": "/contact-us",
      "destination": "https://quoting.interstatecarcarriers.com.au/contact",
      "permanent": true
    },
    {
      "source": "/contact-us/",
      "destination": "https://quoting.interstatecarcarriers.com.au/contact",
      "permanent": true
    },
    {
      "source": "/contact-icc",
      "destination": "https://quoting.interstatecarcarriers.com.au/contact",
      "permanent": true
    },
    {
      "source": "/contact-icc/",
      "destination": "https://quoting.interstatecarcarriers.com.au/contact",
      "permanent": true
    }
  ]
}
